{
  "/": {
    "path": "/",
    "seo": {
      "title": "Home Page",
      "description": "Welcome to our store"
    },
    "layout": [
      {
        "mui": "AppBar",
        "props": {
          "position": "static",
          "sx": {
            "backgroundColor": "white",
            "color": "black",
            "boxShadow": "none",
            "px": 2
          }
        },
        "children": [
          {
            "mui": "Toolbar",
            "props": {
              "sx": {
                "justifyContent": "space-between"
              }
            },
            "children": [
              {
                "mui": "Typography",
                "props": {
                  "variant": "h6",
                  "sx": {
                    "fontWeight": "bold"
                  }
                },
                "children": [
                  {
                    "mui": "span",
                    "props": {
                      "style": {
                        "color": "black"
                      }
                    },
                    "children": "LI"
                  },
                  {
                    "mui": "span",
                    "props": {
                      "style": {
                        "color": "#3b82f6"
                      }
                    },
                    "children": "STING"
                  }
                ]
              },
              {
                "mui": "Box",
                "props": {
                  "sx": {
                    "display": "flex",
                    "alignItems": "center",
                    "gap": 2,
                    "backgroundColor": "#f5f5f5",
                    "borderRadius": "999px",
                    "px": 2,
                    "py": 0.5
                  }
                },
                "children": [
                  {
                    "mui": "NavItem",
                    "props": {
                      "icon": "🎮",
                      "label": "Games",
                      "dropdown": {
                        "platforms": [
                          {
                            "title": "PC",
                            "link": "category",
                            "query": "pc",
                            "count": 1345
                          },
                          {
                            "title": "Home",
                            "link": "/",
                            "count": 12954
                          },
                          {
                            "title": "Xbox",
                            "count": 2344
                          },
                          {
                            "title": "Nintendo",
                            "count": 123
                          }
                        ],
                        "brands": [
                          "Steam",
                          "Ubisoft",
                          "Rockstar",
                          "EA",
                          "Bethesda",
                          "GOG"
                        ]
                      }
                    }
                  },
                  {
                    "mui": "Divider"
                  },
                  {
                    "mui": "NavItem",
                    "props": {
                      "icon": "💻",
                      "label": "Software"
                    }
                  },
                  {
                    "mui": "Divider"
                  },
                  {
                    "mui": "NavItem",
                    "props": {
                      "icon": "💳",
                      "label": "Prepaid Cards"
                    }
                  },
                  {
                    "mui": "Divider"
                  },
                  {
                    "mui": "NavItem",
                    "props": {
                      "icon": "⬇️",
                      "label": "More"
                    }
                  }
                ]
              },
              {
                "mui": "Box",
                "props": {
                  "sx": {
                    "display": "flex",
                    "alignItems": "center",
                    "gap": 1
                  }
                },
                "children": [
                  {
                    "mui": "Button",
                    "props": {
                      "variant": "outlined",
                      "startIcon": "🇬🇧"
                    },
                    "children": "ENG"
                  },
                  {
                    "mui": "Avatar",
                    "props": {
                      "src": "https://randomuser.me/api/portraits/men/75.jpg"
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "mui": "Box",
        "props": {
          "component": "footer",
          "sx": {
            "backgroundColor": "grey.900",
            "color": "white",
            "py": 4,
            "mt": "auto"
          }
        },
        "children": [
          {
            "mui": "Container",
            "children": [
              {
                "mui": "Typography",
                "props": {
                  "variant": "body2",
                  "align": "center"
                },
                "children": "© 2025 Lugnet Green Bistro. Alla rättigheter förbehållna."
              },
              {
                "mui": "Box",
                "props": {
                  "sx": {
                    "display": "flex",
                    "justifyContent": "center",
                    "gap": 2,
                    "mt": 1
                  }
                },
                "children": [
                  {
                    "mui": "Link",
                    "props": {
                      "href": "/integritetspolicy",
                      "underline": "hover",
                      "color": "inherit"
                    },
                    "children": "Integritetspolicy"
                  },
                  {
                    "mui": "Link",
                    "props": {
                      "href": "/kontakt",
                      "underline": "hover",
                      "color": "inherit"
                    },
                    "children": "Kontakt"
                  },
                  {
                    "mui": "Link",
                    "props": {
                      "href": "/om-oss",
                      "underline": "hover",
                      "color": "inherit"
                    },
                    "children": "Om oss"
                  }
                ]
              }
            ]
          }
        ]
      }
    ],
    "main": [
      {
        "mui": "Box",
        "props": {
          "sx": {
            "backgroundImage": "url('https://images.unsplash.com/photo-1504674900247-0877df9cc836?auto=format&fit=crop&w=1600&q=80')",
            "backgroundSize": "cover",
            "backgroundPosition": "center",
            "py": 10,
            "color": "white",
            "textAlign": "center"
          }
        },
        "children": [
          {
            "mui": "Container",
            "children": [
              {
                "mui": "Typography",
                "props": {
                  "variant": "h2",
                  "sx": {
                    "fontWeight": "bold",
                    "mb": 2
                  }
                },
                "children": "Welcome to Lugnet Green Bistro"
              },
              {
                "mui": "Typography",
                "props": {
                  "variant": "h5",
                  "sx": {
                    "mb": 4
                  }
                },
                "children": "Healthy, delicious, and sustainable meals for every moment."
              },
              {
                "mui": "Button",
                "props": {
                  "variant": "contained",
                  "color": "primary",
                  "href": "/menu"
                },
                "children": "View Our Menu"
              }
            ]
          }
        ]
      }
    ]
  },
